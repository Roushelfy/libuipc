  "global_forbidden_patterns": [
    {
      "pattern": "\\bcudaMalloc(?:Async)?\\s*\\(",
      "reason": "cuda_mixed code should allocate through muda::Memory or BufferLaunch."
    },
    {
      "pattern": "\\bcudaFree(?:Async)?\\s*\\(",
      "reason": "cuda_mixed code should free through muda::Memory or BufferLaunch."
    }
  ],
  "file_rules": [
    {
      "path": "src/backends/cuda_mixed/affine_body/bdf/affine_body_bdf1_kinetic.cu",
      "required_patterns": [
        {
          "pattern": "to_mat_t<Alu>",
          "reason": "BDF1 kinetic must keep the dyadic mass matrix in the active ALU type."
        }
      ],
      "forbidden_patterns": [
        {
          "pattern": "to_mat\\(\\)\\.template cast<Alu>",
          "reason": "BDF1 kinetic must not materialize Float matrices and cast them back to Alu."
        }
      ]
    },
    {
      "path": "src/backends/cuda_mixed/affine_body/bdf/affine_body_bdf2_kinetic.cu",
      "required_patterns": [
        {
          "pattern": "to_mat_t<Alu>",
          "reason": "BDF2 kinetic must keep the dyadic mass matrix in the active ALU type."
        }
      ],
      "forbidden_patterns": [
        {
          "pattern": "to_mat\\(\\)\\.template cast<Alu>",
          "reason": "BDF2 kinetic must not materialize Float matrices and cast them back to Alu."
        }
      ]
    },
    {
      "path": "src/backends/cuda_mixed/affine_body/constraints/soft_transform_constraint.cu",
      "required_patterns": [
        {
          "pattern": "to_mat_t<T>",
          "reason": "SoftTransformConstraint must build policy-typed mass matrices directly."
        }
      ],
      "forbidden_patterns": [
        {
          "pattern": "to_mat\\(\\)\\.template cast<",
          "reason": "SoftTransformConstraint must not add intermediate Float matrix casts."
        }
      ]
    },
    {
      "path": "src/backends/cuda_mixed/affine_body/abd_jacobi_matrix.h",
      "required_patterns": [
        {
          "pattern": "template <typename Scalar>\\s+MUDA_GENERIC Matrix<Scalar, 3, 12> to_mat_t\\(\\) const;",
          "reason": "ABDJacobi must expose a templated to_mat_t helper for mixed precision."
        },
        {
          "pattern": "template <typename Scalar>\\s+MUDA_GENERIC Matrix<Scalar, 3 \\* N, 12> to_mat_t\\(\\) const;",
          "reason": "ABDJacobiStack must expose a templated to_mat_t helper for mixed precision."
        }
      ]
    },
    {
      "path": "src/backends/cuda_mixed/affine_body/details/abd_jacobi_matrix.inl",
      "required_patterns": [
        {
          "pattern": "return to_mat_t<Float>\\(\\);",
          "reason": "ABDJacobiStack::to_mat should stay a thin wrapper over to_mat_t<Float>()."
        },
        {
          "pattern": "m_jacobis\\[i\\]->template to_mat_t<Scalar>\\(\\)",
          "reason": "ABDJacobiStack assembly must use templated to_mat_t dispatch."
        }
      ],
      "forbidden_patterns": [
        {
          "pattern": "to_mat\\(\\)\\.template cast<",
          "reason": "ABDJacobi hot paths must not rebuild Float matrices and cast them into mixed ALU types."
        }
      ]
    },
    {
      "path": "src/backends/cuda_mixed/affine_body/constraints/external_articulation_constraint.cu",
      "required_patterns": [
        {
          "pattern": "DeviceBuffer<InternalScalar> joint_id_to_delta_theta;",
          "reason": "External articulation delta-theta scratch must use InternalScalar."
        },
        {
          "pattern": "DeviceBuffer<InternalScalar> joint_id_to_delta_theta_tilde;",
          "reason": "External articulation delta-theta-tilde scratch must use InternalScalar."
        },
        {
          "pattern": "DeviceBuffer<InternalScalar> joint_joint_id_to_mass;",
          "reason": "External articulation mass coupling scratch must use InternalScalar."
        }
      ],
      "line_watch_patterns": [
        {
          "pattern": "DeviceBuffer<Float>",
          "reason": "External articulation compute scratch must not regress to Float device buffers."
        }
      ]
    },
    {
      "path": "src/backends/cuda_mixed/finite_element/fem_diag_preconditioner.cu",
